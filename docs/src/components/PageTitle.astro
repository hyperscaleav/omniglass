---
// Override of Starlight's PageTitle: renders the page H1 plus, when the page
// declares a `sidebar.badge` in its frontmatter, the same badge next to the
// title. One source of truth (sidebar.badge) drives both the nav badge and the
// on-page badge, so a Spec / Building / Built status shows on the page itself.
import { Badge } from '@astrojs/starlight/components';

const { data } = Astro.locals.starlightRoute.entry;
const raw = data.sidebar?.badge;
const badge = raw ? (typeof raw === 'string' ? { text: raw, variant: 'default' } : raw) : null;
---

<div class="page-title-row">
  <h1 id="_top">{data.title}</h1>
  {badge && <Badge text={badge.text} variant={badge.variant} size="medium" />}
</div>

<style>
  .page-title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  @layer starlight.core {
    .page-title-row h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-white);
    }
  }
</style>
