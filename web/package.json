    "@testing-library/jest-dom": "^6.9.1",
    "daisyui": "^5.0.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
